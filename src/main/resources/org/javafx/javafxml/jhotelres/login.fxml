<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="org.javafx.javafxml.jhotelres.Login"
            prefHeight="400.0" prefWidth="600.0">

        <children>
            <Label layoutX="30" layoutY="30" text="Product-ID eingeben:" />
            <TextField fx:id="productIdField" layoutX="30" layoutY="60" prefWidth="200" />
            <Button layoutX="30" layoutY="100" text="Anmelden" onAction="#handleLogin"/>
            <Label fx:id="errorLabel" layoutX="30" layoutY="140" textFill="red"/>
        </children>
    </AnchorPane>


